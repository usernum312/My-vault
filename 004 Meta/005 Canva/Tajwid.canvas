		{"id":"826c64ad544ae10b","type":"text","text":"وهو قراءة عادية للنون (بدون غنة)\nشرط أن يتبعها احد الحروف الآتية","x":603,"y":335,"width":195,"height":142},
		{"id":"24cc8001a6ead697","type":"text","text":"الحروف المهموسة ","x":1898,"y":-40,"width":182,"height":64,"color":"#212121"},
		{"id":"bd53ea2c909a96c7","type":"text","text":"أخي هاك علما حازه غير خاسر","x":1100,"y":373,"width":165,"height":77},
		{"id":"8ee87c5250a8fa1c","type":"text","text":"حروف الاظهار","x":1400,"y":280,"width":170,"height":60,"color":"2"},
		{"id":"f60806be7f6a9950","type":"text","text":"أ، ه، ع، ح، غ، خ","x":1100,"y":285,"width":165,"height":50},
		{"id":"952f5037179c9604","type":"text","text":"وهي قراءة عادية (بدون غنة) الميم الساكنة إذا أتت بعدها","x":278,"y":1141,"width":257,"height":101},
		{"id":"308e4e12094b2bcd","type":"text","text":"الاظهار الشفوي","x":589,"y":1191,"width":173,"height":60},
		{"id":"56bf771d0276dc4f","type":"text","text":"وهو أن تأتي بعد الميم الساكنة ميم متحركة **فيصبحان ميما واحدة مشددة مع الغنة**","x":-30,"y":974,"width":260,"height":113},
