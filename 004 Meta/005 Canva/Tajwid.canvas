		{"id":"80f8baee276ed25f","type":"text","text":"ن --- ب ---> اقلاب \nمثال:\nصم *ب*كم\nتقرأ صممبكم\n","x":-320,"y":20,"width":240,"height":140},
		{"id":"2c62b16c8f2fcfb5","type":"text","text":"الاقلاب","x":80,"y":-120,"width":120,"height":50},
		{"id":"eace902ba5ec6e70","type":"text","text":"هو قلب النون الساكنة ميما شرط أن يتبعها باء","x":20,"y":23,"width":160,"height":143},
		{"id":"b3d3a07ace842a74","type":"text","text":"صف ذا ثنا كم جاد شخص قد سما دم طيبا زد في تقى ضع ظالما","x":1100,"y":-9,"width":260,"height":93},
		{"id":"30aa9791688a446f","type":"text","text":"ص، ذ، ث، ك، ج، ش، ق، س، د، ط، ز، ف، ت، ض، ظ","x":1275,"y":140,"width":250,"height":60},
		{"id":"e739f7c62c05ad6d","type":"text","text":"وهم *ص*اغرون - لهم *ج*نات - أم*ط*رنا","x":-291,"y":1133,"width":250,"height":60},
		{"id":"e933aba281a9a85f","type":"text","text":"**كل الحروف** ***إلا*** الباء والميم","x":-108,"y":1242,"width":250,"height":60},
		{"id":"5cc20eaf84fe144c","type":"text","text":"ومنه*مْ* *م*ن ---> ومنه*مّ*ن\nك*مْ* *م*ن ---> ك*مّ*ن","x":-330,"y":901,"width":220,"height":73},
		{"id":"3170e922ef169b86","type":"text","text":"حروف الاخفاء","x":1400,"y":-24,"width":167,"height":62,"color":"#2e2e2e"},
		{"id":"0f1d85bca6b74a0d","type":"text","text":"**مثال**:\nجنات *ت*جري ---> جنات**ن** **ت**جري","x":-40,"y":216,"width":168,"height":111},
		{"id":"fcece2d742535bd9","type":"text","text":"ص، ذ، ث، ك، ج، ش، ق، س، د، ط، ز، ف، ت، ض، ظ","x":-320,"y":393,"width":180,"height":102},
		{"id":"a6fea5c4f7ca472d","type":"text","text":"*ص*ف *ذ*ا *ث*نا *ك*م *ج*اد *ش*خص *ق*د *س*ما، *د*م *ط*يبا *ز*د *ف*ي *ت*قى *ض*ع *ظ*الما","x":-320,"y":216,"width":240,"height":111},
		{"id":"422eb1f056c9cd1a","type":"text","text":"*أ*خي *ه*اك *ع*لما *ح*ازه *غ*ير *خ*اسر","x":425,"y":220,"width":275,"height":50},
		{"id":"f5e943940d350165","type":"text","text":"مع غنة","x":275,"y":-100,"width":115,"height":50},
		{"id":"f9beef3f8a7b4612","type":"text","text":"ينمو","x":440,"y":-100,"width":90,"height":50},
		{"id":"6a2710e2796d8673","type":"text","text":" عدم التلفظ بالنون\nفإما أن تمحى النون بشكل كامل أو جزئيا (تبقى غنتها)","x":530,"y":40,"width":210,"height":140},
		{"id":"9ed6fcf7dab6710a","type":"text","text":"أ، ه، ع، ح، غ، خ","x":395,"y":427,"width":160,"height":50},
		{"id":"66e86b746575a770","type":"text","text":"ويقع بين الاظهار والادغام حيث أنك لا تنطق النون كما في الإظهار ولا تنزعها كما في الادغام ولكن تخفيها وتبقي على الغنة وحروفها هم","x":-107,"y":340,"width":287,"height":155},
		{"id":"cc22f19860169406","type":"text","text":"الإخفاء","x":148,"y":240,"width":100,"height":50},
		{"id":"0ad81a4e2c9368bf","type":"text","text":"حثه شخص فسكت","x":1600,"y":84,"width":200,"height":56},
		{"id":"64cf8f94391d2857","type":"text","text":"حروف الاستعلاء","x":1880,"y":280,"width":180,"height":60,"color":"#0000ff"},
